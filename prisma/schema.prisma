generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  privyId       String        @unique
  email         String?       @unique
  name          String?
  avatar        String?
  upiId         String?
  phone         String?
  theme         String        @default("dark")
  referralCode  String        @unique @default(cuid())
  referredBy    String?
  isVerified    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  wallet        Wallet?
  transactions  Transaction[]
  offers        Offer[]
  referrals     Referral[]    @relation("ReferralReferrer")
  referredUsers Referral[]    @relation("ReferralReferred")

  @@map("users")
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  address          String   @unique
  depositAddress   String?  @unique   // Per-user HD wallet deposit address
  derivationIndex  Int?     @unique   // BIP44 index for HD wallet derivation
  inrBalance       Float    @default(0)
  usdtBalance      Float    @default(0)
  btcBalance       Float    @default(0)
  ethBalance       Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  asset           String
  amount          Float
  fee             Float             @default(0)
  networkFee      Float             @default(0)
  fromAddress     String?
  toAddress       String?
  txHash          String?
  upiRef          String?
  depositAddress  String?
  externalRef     String?
  notes           String?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Offer {
  id          String      @id @default(cuid())
  userId      String
  type        OfferType
  asset       String
  amount      Float
  price       Float
  minLimit    Float
  maxLimit    Float
  paymentMethod String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("offers")
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String
  reward      Float    @default(0)
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())

  referrer    User     @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referred    User     @relation("ReferralReferred", fields: [referredId], references: [id])

  @@map("referrals")
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BUY
  SELL
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum OfferType {
  BUY
  SELL
}
